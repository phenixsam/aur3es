#!/bin/bash
#
# Pre-commit hooks for Golden RNG
# Install with: cp .git/hooks/pre-commit .git/hooks/pre-commit.bak && cp scripts/pre-commit .git/hooks/pre-commit
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Running pre-commit checks..."

# Check for staged C source files
STAGED_C_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|h)$' || true)

if [ -z "$STAGED_C_FILES" ]; then
    echo "No C files to check."
    exit 0
fi

# Get project root
PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# Check 1: Coding style (basic checks)
echo "Checking code style..."
for file in $STAGED_C_FILES; do
    # Check for tabs
    if grep -q $'\t' "$file"; then
        echo -e "${YELLOW}Warning: $file contains tabs. Use spaces for indentation.${NC}"
    fi
    
    # Check for trailing whitespace
    if grep -q '[[:space:]]$' "$file"; then
        echo -e "${YELLOW}Warning: $file contains trailing whitespace.${NC}"
    fi
done

# Check 2: Basic syntax check
echo "Checking syntax..."
for file in $STAGED_C_FILES; do
    gcc -fsyntax-only -I src/ -I src/core -I src/platform -I src/utils "$file" 2>/dev/null || {
        echo -e "${RED}Syntax error in $file${NC}"
        exit 1
    }
done

# Check 3: No debug prints in release code
echo "Checking for debug code..."
DEBUG_PATTERNS="printf.*DEBUG|fflush.*stdout"
for file in $STAGED_C_FILES; do
    if grep -qE "$DEBUG_PATTERNS" "$file"; then
        echo -e "${YELLOW}Warning: $file may contain debug code.${NC}"
    fi
done

# Check 4: Security checks
echo "Checking for security issues..."
for file in $STAGED_C_FILES; do
    # Check for gets() (deprecated)
    if grep -q '\bgets\b' "$file"; then
        echo -e "${RED}Error: $file uses deprecated gets()${NC}"
        exit 1
    fi
    
    # Check for strcpy/strcat (use strncpy/strncat instead)
    if grep -q '\bstrcpy\s*(' "$file" && ! grep -q 'strncpy' "$file"; then
        echo -e "${YELLOW}Warning: $file uses strcpy. Consider using strncpy.${NC}"
    fi
done

echo -e "${GREEN}All pre-commit checks passed!${NC}"
exit 0

